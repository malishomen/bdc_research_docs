      "function": "session_create",
      "description": "Generates a new claude subprocess linked to a unique session UUID",
      "status": "implemented_and_measured",
      "evidence": "3/3 success, RAW_EVIDENCE/session_trace_01.jsonl"
    },
    {
      "function": "permission_approval",
      "description": "Bridges tool_use events to operator, pauses execution until REST endpoint releases the block",
      "status": "implemented_and_measured",
      "evidence": "3/3 round-trips successful, RAW_EVIDENCE/session_trace_05.jsonl"
    },
    {
      "function": "follow_up_query",
      "description": "Sends successive prompts into an ongoing conversational frame",
      "status": "implemented_but_broken",
      "evidence": "3/3 lost prior context \u2014 new subprocess spawned each time, RAW_EVIDENCE/session_trace_04.jsonl"
