    {
      "function": "session_recovery_after_reload",
      "description": "Re-hydrating active states if the operator refreshes the browser tab",
      "status": "not_implemented",
      "evidence": "0/3 recovery, STATE_LOSS_ON_TCP_RESET"
    },
    {
      "function": "file_write_verification",
      "description": "Bounding filesystem outputs to the specified cwd directory",
      "status": "implemented_not_measured",
      "evidence": "No isolated measurement, relies on claude CLI internal sandboxing"
    }
  ],
